{
  "name": "cinema-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "admin": "npx --yes serve admin -l 3001",
    "backend": "cd backend && .venv/bin/python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "backend:install": "cd backend && python3.13 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "dependencies": {
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.35",
    "expo-status-bar": "~3.0.9",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}

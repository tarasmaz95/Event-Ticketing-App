{
  "name": "cinema-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "admin": "npx --yes serve admin -l 3001",
    "backend": "cd backend && .venv/bin/python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "backend:install": "cd backend && python3.13 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "dependencies": {
    "expo": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  }
}
